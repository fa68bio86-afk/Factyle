# Factyle API key template.
#
# Usage:
#   cp .env.example .env
#   edit .env with local credentials
#
# The .env file is ignored by git. Never commit real credentials.

# Baidu AI Search API, used by Module 2 external evidence retrieval.
BAIDU_SEARCH_API_KEY="your_baidu_search_api_key"

# Qwen API via DashScope OpenAI-compatible endpoint.
# Used by Module 2 entity extraction and Module 3 style rewriting/analysis.
QWEN_API_KEY="your_qwen_api_key"
QWEN_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
